-- Find intersection;
create table tmp_1m.kn_x_mbi_202412_2025ytd as
select 
	coalesce(a.mbi, b.mbi) as mbi
from tmp_1m.kn_distinct_mbi_202412 as a
inner join tmp_1m.kn_distinct_mbi_2025ytd as b
on a.mbi = b.mbi
;

