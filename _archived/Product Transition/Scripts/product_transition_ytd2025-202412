	b.fin_brand 
	, b.fin_tfm_product_new 
	, b.fin_g_i 
	, b.fin_product_level_3 
	, b.fin_inc_year
	, b.fin_inc_month
 	, count(distinct b.fin_mbi_hicn_fnl) as mbrs
from tmp_1m.kn_distinct_mbi_202412 as a
